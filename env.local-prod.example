# Скопируйте в .env.local-prod (файл в git не коммитится):
#   cp env.local-prod.example .env.local-prod
#
# Запуск (два compose-файла): перед backend автоматически выполняется перенос
# ./backend/education.db → PostgreSQL (migrate_sqlite_to_pg.py --force). Держите актуальный education.db в репозитории.
#
#   docker compose -p lms-local --env-file .env.local-prod \
#     -f docker-compose.vps.yml -f docker-compose.local-prod.yml up -d --build
#
# Повторно только перезалить SQLite без полного up: ./scripts/import_sqlite_to_local_docker_pg.sh

SECRET_KEY=dev-local-change-me-use-openssl-rand-hex-32

# Браузер ходит на Next :3000 — те же origin'ы, что и при локальном фронте
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_PUBLIC_URL=http://localhost:3000

POSTGRES_USER=lms
POSTGRES_PASSWORD=lms_local_dev_only
POSTGRES_DB=education_platform

# ИИ: как на проде — без ключа чат отдаёт демо-текст из backend
OPENAI_API_KEY=
GEMINI_API_KEY=

# Лимит попыток входа с одного IP (slowapi). Для активных тестов можно 200/minute
# AUTH_LOGIN_RATELIMIT=120/minute

# В docker-compose.local-prod.yml для backend уже LMS_SKIP_ENTRYPOINT_SEED=1 (сиды не трогают перенос).
# Дублируйте здесь при необходимости; на VPS после ручного импорта — в .env.deploy.
LMS_SKIP_ENTRYPOINT_SEED=1

# Почта (опционально)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true
