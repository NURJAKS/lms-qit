# Скопируйте в .env.local-prod (файл в git не коммитится):
#   cp env.local-prod.example .env.local-prod
#
# Запуск стека «как прод» локально (два compose-файла: база как VPS + порты для отладки):
#   docker compose -p lms-local --env-file .env.local-prod \
#     -f docker-compose.vps.yml -f docker-compose.local-prod.yml up -d --build

SECRET_KEY=dev-local-change-me-use-openssl-rand-hex-32

# Браузер ходит на Next :3000 — те же origin'ы, что и при локальном фронте
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_PUBLIC_URL=http://localhost:3000

POSTGRES_USER=lms
POSTGRES_PASSWORD=lms_local_dev_only
POSTGRES_DB=education_platform

# ИИ: как на проде — без ключа чат отдаёт демо-текст из backend
OPENAI_API_KEY=
GEMINI_API_KEY=

# Почта (опционально)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true
