# Скопируйте в .env.deploy в корне репозитория и подставьте значения:
#   cp env.deploy.example .env.deploy
#
# Используется для: docker compose --env-file .env.deploy -f docker-compose.vps.yml …
# Локально «как прод»: env.local-prod.example → .env.local-prod и два файла compose (см. env.local-prod.example).
# Файл .env.deploy в git не коммитьте.
#
# Порты: фронт на хосте — 3000 (или другой, если занят). Бэкенд :8000 не пробрасывается на хост,
# чтобы не конфликтовать с другим проектом на VPS; API доступен через /api с того же домена.

# Обязательно смените (например: openssl rand -hex 32)
SECRET_KEY=replace_with_long_random_string

# Все origin'ы браузера, с которых идут запросы к API (через запятую, без пробелов).
# Пример продакшена (после Certbot, HTTPS):
# ALLOWED_ORIGINS=https://qazaqitacademy-edu.pp.ua,https://www.qazaqitacademy-edu.pp.ua,http://localhost:3000
ALLOWED_ORIGINS=https://qazaqitacademy-edu.pp.ua,https://www.qazaqitacademy-edu.pp.ua,http://localhost:3000

# Публичный URL фронта (ссылки в письмах и редиректах)
FRONTEND_PUBLIC_URL=https://qazaqitacademy-edu.pp.ua

# PostgreSQL (docker-compose.vps.yml). Задайте надёжный пароль; файл .env.deploy не коммитьте.
POSTGRES_USER=lms
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=education_platform

# ИИ (опционально). Без ключей чат показывает демо-текст, AI Challenge — локальная симуляция.
# Приоритет: если задан OPENAI_API_KEY — используется OpenAI; иначе при наличии GEMINI_API_KEY — Gemini.
OPENAI_API_KEY=
GEMINI_API_KEY=
# Необязательно — переопределение моделей (по умолчанию в backend: gpt-4o-mini и gemini-2.0-flash)
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_CHALLENGE_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash
