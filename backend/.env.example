DATABASE_URL=postgresql://postgres:postgres@localhost:5432/education_platform
SECRET_KEY=your-secret-key-change-in-production
OPENAI_API_KEY=sk-your-openai-api-key
# Альтернатива OpenAI — Gemini (приоритет, если задан)
GEMINI_API_KEY=
UPLOAD_DIR=./uploads
# Цена Premium в тенге
PREMIUM_PRICE_TENGE=199999

# CORS: через запятую все origin фронта.
# Продакшен: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# AI Challenge: если Web-курс в БД под другим названием — укажите его id (например 2)
# AI_CHALLENGE_WEB_COURSE_ID=2
# AI Challenge: курс «Информатика және АТ негіздері» (общая ИТ, не Python) — при несовпадении названия
# AI_CHALLENGE_INFORMATICS_COURSE_ID=3
# AI Challenge: курс «Кибер қауіпсіздік негіздері»
# AI_CHALLENGE_CYBER_COURSE_ID=

# SMTP настройки для Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true