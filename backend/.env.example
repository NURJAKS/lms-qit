# Скопируйте в backend/.env и подставьте свои значения (файл .env в git не кладём):
#   cp backend/.env.example backend/.env
#
# Демо по умолчанию — SQLite один файл рядом с приложением (удобно для проверяющих).

DATABASE_URL=sqlite:///./education.db
SECRET_KEY=change_me_generate_long_random_string_for_production
OPENAI_API_KEY=
# Альтернатива OpenAI — Gemini (приоритет, если задан)
GEMINI_API_KEY=
UPLOAD_DIR=./uploads
PREMIUM_PRICE_TENGE=199999

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
FRONTEND_PUBLIC_URL=http://localhost:3000

# --- VPS / production ---
# DEBUG=false
# At least one of OPENAI_API_KEY or GEMINI_API_KEY must be set for AI chat and AI Challenge (see app/services/ai_service.py).
# ALLOWED_ORIGINS must include every browser origin that calls this API (comma-separated), e.g. https://app.example.com
# Run the API behind a process manager (systemd, pm2, supervisord) with restarts on failure.

# PostgreSQL (если нужен вместо SQLite) — раскомментируйте и уберите/закомментируйте DATABASE_URL выше
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/education_platform

# AI Challenge (опционально)
# AI_CHALLENGE_WEB_COURSE_ID=2
# AI_CHALLENGE_INFORMATICS_COURSE_ID=3
# AI_CHALLENGE_CYBER_COURSE_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
